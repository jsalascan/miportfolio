---
// Monigotes robóticos animados (SVG + CSS, sin JS salvo el eye-follow del hero).
// Variantes: "float" (flota con propulsores), "sit" (sentado con café, piernas colgando),
// "wave" (de pie saludando), "peek" (asomándose por un borde), "climb" (trepando una línea
// vertical), "obrero" (operario con casco amarillo y llave inglesa), "fallen" (caído y
// mareado), "sleep" (dormido con Zzz).
const { variant = "float", class: className = "" } = Astro.props

const ink = "#2d2a24"
const banner = "#263c70"
const paper2 = "#f1e5d5"
const accent = "#ff8400"
const cyan = "#34bfff"
const casco = "#ffcc00"
---

{variant === "float" && (
  <svg viewBox="0 0 120 150" fill="none" class={className} aria-hidden="true">
    <ellipse class="mono-shadow" cx="60" cy="142" rx="26" ry="6" fill={ink} opacity="0.2" />
    <g class="mono-float">
      <line x1="60" y1="20" x2="60" y2="10" stroke={ink} stroke-width="3" stroke-linecap="round" />
      <circle class="mono-pulse" cx="60" cy="8" r="4.5" fill={accent} />
      <rect x="32" y="20" width="56" height="42" rx="12" fill={banner} stroke={ink} stroke-width="3" />
      <g data-mono-eyes>
        <g class="mono-blink">
          <circle cx="50" cy="40" r="5.5" fill={cyan} />
          <circle cx="70" cy="40" r="5.5" fill={cyan} />
        </g>
      </g>
      <path d="M52 51 Q60 56 68 51" stroke={cyan} stroke-width="2.5" stroke-linecap="round" />
      <path d="M40 72 Q28 76 26 86" stroke={ink} stroke-width="3" stroke-linecap="round" />
      <circle cx="26" cy="89" r="4.5" fill={paper2} stroke={ink} stroke-width="2.5" />
      <path d="M80 72 Q92 76 94 86" stroke={ink} stroke-width="3" stroke-linecap="round" />
      <circle cx="94" cy="89" r="4.5" fill={paper2} stroke={ink} stroke-width="2.5" />
      <rect x="40" y="66" width="40" height="32" rx="10" fill={paper2} stroke={ink} stroke-width="3" />
      <circle cx="60" cy="82" r="4" fill={accent} />
      <ellipse class="mono-pulse" cx="52" cy="106" rx="4" ry="7" fill={accent} />
      <ellipse class="mono-pulse" cx="68" cy="106" rx="4" ry="7" fill={accent} style="animation-delay: -0.9s" />
    </g>
  </svg>
)}

{variant === "sit" && (
  <svg viewBox="0 0 110 130" fill="none" class={className} aria-hidden="true">
    <g class="mono-swing" style="transform-origin: 47px 82px; animation-delay: -1.2s">
      <rect x="43" y="80" width="8" height="24" rx="4" fill={banner} stroke={ink} stroke-width="2.5" />
      <ellipse cx="47" cy="107" rx="7" ry="4" fill={paper2} stroke={ink} stroke-width="2.5" />
    </g>
    <g class="mono-swing" style="transform-origin: 63px 82px">
      <rect x="59" y="80" width="8" height="24" rx="4" fill={banner} stroke={ink} stroke-width="2.5" />
      <ellipse cx="63" cy="107" rx="7" ry="4" fill={paper2} stroke={ink} stroke-width="2.5" />
    </g>
    <line x1="55" y1="12" x2="55" y2="5" stroke={ink} stroke-width="3" stroke-linecap="round" />
    <circle class="mono-pulse" cx="55" cy="4" r="4" fill={accent} />
    <rect x="28" y="12" width="54" height="40" rx="11" fill={banner} stroke={ink} stroke-width="3" />
    <g class="mono-blink">
      <circle cx="46" cy="31" r="5" fill={cyan} />
      <circle cx="64" cy="31" r="5" fill={cyan} />
    </g>
    <path d="M48 41 Q55 45 62 41" stroke={cyan} stroke-width="2.5" stroke-linecap="round" />
    <path d="M36 60 Q26 66 28 75" stroke={ink} stroke-width="3" stroke-linecap="round" />
    <circle cx="28" cy="77" r="4" fill={paper2} stroke={ink} stroke-width="2.5" />
    <path d="M74 60 Q84 63 84 70" stroke={ink} stroke-width="3" stroke-linecap="round" />
    <rect x="36" y="54" width="38" height="30" rx="9" fill={paper2} stroke={ink} stroke-width="3" />
    <circle cx="55" cy="68" r="3.5" fill={accent} />
    <rect x="79" y="66" width="13" height="11" rx="2.5" fill={accent} stroke={ink} stroke-width="2.5" />
    <path d="M92 69 q5 2 0 5" stroke={ink} stroke-width="2.5" fill="none" />
    <path d="M83 62 q1 -3 3 -4 M88 62 q1 -3 3 -4" stroke={ink} stroke-width="1.5" stroke-linecap="round" opacity="0.5" />
  </svg>
)}

{variant === "wave" && (
  <svg viewBox="0 0 110 140" fill="none" class={className} aria-hidden="true">
    <ellipse cx="55" cy="127" rx="26" ry="5" fill={ink} opacity="0.15" />
    <g class="mono-wave" style="transform-box: view-box; transform-origin: 74px 64px">
      <path d="M74 64 Q88 56 92 44" stroke={ink} stroke-width="3" stroke-linecap="round" />
      <circle cx="93" cy="41" r="5" fill={paper2} stroke={ink} stroke-width="2.5" />
    </g>
    <line x1="55" y1="14" x2="55" y2="7" stroke={ink} stroke-width="3" stroke-linecap="round" />
    <circle class="mono-pulse" cx="55" cy="5.5" r="4" fill={accent} />
    <rect x="28" y="14" width="54" height="40" rx="11" fill={banner} stroke={ink} stroke-width="3" />
    <g class="mono-blink">
      <circle cx="46" cy="34" r="5" fill={cyan} />
      <circle cx="64" cy="34" r="5" fill={cyan} />
    </g>
    <path d="M46 44 Q55 50 64 44" stroke={cyan} stroke-width="2.5" stroke-linecap="round" />
    <path d="M36 64 Q25 70 26 80" stroke={ink} stroke-width="3" stroke-linecap="round" />
    <circle cx="26" cy="83" r="4.5" fill={paper2} stroke={ink} stroke-width="2.5" />
    <rect x="36" y="58" width="38" height="32" rx="9" fill={paper2} stroke={ink} stroke-width="3" />
    <circle cx="55" cy="74" r="3.5" fill={accent} />
    <rect x="44" y="88" width="8" height="26" rx="4" fill={banner} stroke={ink} stroke-width="2.5" />
    <rect x="58" y="88" width="8" height="26" rx="4" fill={banner} stroke={ink} stroke-width="2.5" />
    <ellipse cx="48" cy="117" rx="8" ry="4.5" fill={paper2} stroke={ink} stroke-width="2.5" />
    <ellipse cx="62" cy="117" rx="8" ry="4.5" fill={paper2} stroke={ink} stroke-width="2.5" />
  </svg>
)}

{variant === "peek" && (
  <svg viewBox="0 0 120 70" fill="none" class={className} aria-hidden="true">
    <line x1="60" y1="18" x2="60" y2="10" stroke={ink} stroke-width="3" stroke-linecap="round" />
    <circle class="mono-pulse" cx="60" cy="8" r="4" fill={accent} />
    <rect x="33" y="18" width="54" height="44" rx="11" fill={banner} stroke={ink} stroke-width="3" />
    <g class="mono-look">
      <circle cx="51" cy="40" r="5" fill={cyan} />
      <circle cx="69" cy="40" r="5" fill={cyan} />
    </g>
    <circle cx="29" cy="62" r="4.5" fill={paper2} stroke={ink} stroke-width="2.5" />
    <circle cx="91" cy="62" r="4.5" fill={paper2} stroke={ink} stroke-width="2.5" />
  </svg>
)}

{variant === "climb" && (
  <svg viewBox="0 0 60 130" fill="none" class={className} aria-hidden="true">
    <path d="M22 32 Q14 28 13 18" stroke={ink} stroke-width="3" stroke-linecap="round" />
    <circle cx="12" cy="15" r="4.5" fill={paper2} stroke={ink} stroke-width="2.5" />
    <rect x="17" y="26" width="40" height="30" rx="9" fill={banner} stroke={ink} stroke-width="3" />
    <g class="mono-blink">
      <circle cx="31" cy="40" r="4.5" fill={cyan} />
      <circle cx="45" cy="40" r="4.5" fill={cyan} />
    </g>
    <path d="M33 48 Q38 51 43 48" stroke={cyan} stroke-width="2.5" stroke-linecap="round" />
    <path d="M24 66 Q15 70 13 76" stroke={ink} stroke-width="3" stroke-linecap="round" />
    <circle cx="12" cy="79" r="4.5" fill={paper2} stroke={ink} stroke-width="2.5" />
    <rect x="22" y="58" width="32" height="28" rx="8" fill={paper2} stroke={ink} stroke-width="3" />
    <circle cx="38" cy="72" r="3.5" fill={accent} />
    <g class="mono-swing" style="transform-origin: 31px 86px; animation-delay: -1.2s">
      <rect x="27" y="84" width="7" height="22" rx="3.5" fill={banner} stroke={ink} stroke-width="2.5" />
      <ellipse cx="30.5" cy="109" rx="6" ry="3.5" fill={paper2} stroke={ink} stroke-width="2.5" />
    </g>
    <g class="mono-swing" style="transform-origin: 45px 86px">
      <rect x="41" y="84" width="7" height="22" rx="3.5" fill={banner} stroke={ink} stroke-width="2.5" />
      <ellipse cx="44.5" cy="109" rx="6" ry="3.5" fill={paper2} stroke={ink} stroke-width="2.5" />
    </g>
  </svg>
)}

{variant === "obrero" && (
  <svg viewBox="0 0 110 160" fill="none" class={className} aria-hidden="true">
    <ellipse cx="55" cy="150" rx="34" ry="5" fill={ink} opacity="0.15" />

    <!-- Inspector con casco pasando revista -->
    <rect x="28" y="36" width="54" height="40" rx="11" fill={banner} stroke={ink} stroke-width="3" />
    <path d="M31 38 q2 -16 24 -16 q22 0 24 16 Z" fill={casco} stroke={ink} stroke-width="3" />
    <rect x="22" y="36" width="66" height="7" rx="3.5" fill={casco} stroke={ink} stroke-width="2.5" />
    <g class="mono-blink">
      <circle cx="47" cy="59" r="5" fill={cyan} />
      <circle cx="65" cy="59" r="5" fill={cyan} />
    </g>
    <path d="M48 68 Q56 72 64 68" stroke={cyan} stroke-width="2.5" stroke-linecap="round" />

    <rect x="35" y="80" width="40" height="34" rx="9" fill={paper2} stroke={ink} stroke-width="3" />
    <circle cx="55" cy="97" r="3.5" fill={accent} />

    <!-- Portapapeles en la mano izquierda -->
    <path d="M35 88 Q24 92 22 100" stroke={ink} stroke-width="3" stroke-linecap="round" />
    <g transform="rotate(-8 21 116)">
      <rect x="7" y="100" width="28" height="36" rx="3" fill="#ffffff" stroke={ink} stroke-width="2.5" />
      <rect x="15" y="96" width="12" height="7" rx="2.5" fill={ink} />
      <path d="M12 112 l3 3 5 -6" stroke={accent} stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round" />
      <line x1="23" y1="112" x2="30" y2="112" stroke={ink} stroke-width="2" opacity="0.3" />
      <path d="M12 122 l3 3 5 -6" stroke={accent} stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round" />
      <line x1="23" y1="122" x2="30" y2="122" stroke={ink} stroke-width="2" opacity="0.3" />
      <line x1="12" y1="131" x2="30" y2="131" stroke={ink} stroke-width="2" opacity="0.3" />
    </g>

    <!-- Mano derecha con lápiz, apuntando -->
    <path d="M75 88 Q88 92 88 102" stroke={ink} stroke-width="3" stroke-linecap="round" />
    <g class="wrench-turn" style="transform-box: view-box; transform-origin: 88px 104px">
      <circle cx="88" cy="104" r="4.5" fill={paper2} stroke={ink} stroke-width="2.5" />
      <line x1="85" y1="107" x2="76" y2="118" stroke={casco} stroke-width="4" stroke-linecap="round" />
      <path d="M76 118 l-3 4 l1 -5 Z" fill={ink} />
    </g>

    <!-- Piernas -->
    <rect x="43" y="112" width="8" height="28" rx="4" fill={banner} stroke={ink} stroke-width="2.5" />
    <rect x="59" y="112" width="8" height="28" rx="4" fill={banner} stroke={ink} stroke-width="2.5" />
    <ellipse cx="47" cy="143" rx="8" ry="4.5" fill={paper2} stroke={ink} stroke-width="2.5" />
    <ellipse cx="63" cy="143" rx="8" ry="4.5" fill={paper2} stroke={ink} stroke-width="2.5" />
  </svg>
)}

{variant === "scrollbot" && (
  <svg viewBox="0 0 60 90" fill="none" class={className} aria-hidden="true">
    <!-- Pulgar de la barra de scroll -->
    <rect x="44" y="18" width="10" height="52" rx="5" fill={accent} stroke={ink} stroke-width="2.5" />

    <!-- Robot colgado tirando -->
    <line x1="21" y1="8" x2="21" y2="3" stroke={ink} stroke-width="2.5" stroke-linecap="round" />
    <circle class="mono-pulse" cx="21" cy="2.5" r="2.5" fill={accent} />
    <rect x="4" y="8" width="34" height="26" rx="8" fill={banner} stroke={ink} stroke-width="2.5" />
    <g class="mono-blink">
      <circle cx="15" cy="21" r="3.5" fill={cyan} />
      <circle cx="28" cy="21" r="3.5" fill={cyan} />
    </g>
    <path d="M16 28 Q21 31 26 28" stroke={cyan} stroke-width="2" stroke-linecap="round" />

    <path d="M34 40 Q40 34 44 30" stroke={ink} stroke-width="2.5" stroke-linecap="round" />
    <circle cx="45" cy="29" r="3.5" fill={paper2} stroke={ink} stroke-width="2" />
    <path d="M34 48 Q40 50 44 52" stroke={ink} stroke-width="2.5" stroke-linecap="round" />
    <circle cx="45" cy="53" r="3.5" fill={paper2} stroke={ink} stroke-width="2" />

    <rect x="8" y="36" width="26" height="22" rx="7" fill={paper2} stroke={ink} stroke-width="2.5" />
    <circle cx="21" cy="47" r="3" fill={accent} />

    <g class="mono-swing" style="transform-origin: 15px 58px; animation-delay: -1.2s">
      <rect x="12" y="57" width="6" height="16" rx="3" fill={banner} stroke={ink} stroke-width="2" />
      <ellipse cx="15" cy="75" rx="5" ry="3" fill={paper2} stroke={ink} stroke-width="2" />
    </g>
    <g class="mono-swing" style="transform-origin: 27px 58px">
      <rect x="24" y="57" width="6" height="16" rx="3" fill={banner} stroke={ink} stroke-width="2" />
      <ellipse cx="27" cy="75" rx="5" ry="3" fill={paper2} stroke={ink} stroke-width="2" />
    </g>
  </svg>
)}

{variant === "fallen" && (
  <svg viewBox="0 0 140 110" fill="none" class={className} aria-hidden="true">
    <ellipse cx="78" cy="100" rx="46" ry="6" fill={ink} opacity="0.15" />
    <g class="mono-dizzy">
      <path d="M104 14 l0 8 M100 18 l8 0" stroke={accent} stroke-width="2.5" stroke-linecap="round" />
      <path d="M124 28 l0 7 M120.5 31.5 l7 0" stroke={accent} stroke-width="2" stroke-linecap="round" opacity="0.7" />
      <path d="M92 34 l0 6 M89 37 l6 0" stroke={accent} stroke-width="2" stroke-linecap="round" opacity="0.7" />
    </g>
    <g class="mono-swing" style="transform-origin: 48px 74px; animation-delay: -1.2s">
      <rect x="44" y="46" width="7" height="28" rx="3.5" fill={banner} stroke={ink} stroke-width="2.5" />
      <ellipse cx="47.5" cy="44" rx="6" ry="3.5" fill={paper2} stroke={ink} stroke-width="2.5" />
    </g>
    <g class="mono-swing" style="transform-origin: 60px 74px">
      <rect x="56" y="42" width="7" height="32" rx="3.5" fill={banner} stroke={ink} stroke-width="2.5" />
      <ellipse cx="59.5" cy="40" rx="6" ry="3.5" fill={paper2} stroke={ink} stroke-width="2.5" />
    </g>
    <path d="M44 84 Q34 90 26 92" stroke={ink} stroke-width="3" stroke-linecap="round" />
    <circle cx="23" cy="93" r="4.5" fill={paper2} stroke={ink} stroke-width="2.5" />
    <rect x="40" y="68" width="38" height="30" rx="9" fill={paper2} stroke={ink} stroke-width="3" transform="rotate(-4 59 83)" />
    <circle cx="58" cy="83" r="3.5" fill={accent} />
    <rect x="80" y="62" width="48" height="36" rx="10" fill={banner} stroke={ink} stroke-width="3" transform="rotate(4 104 80)" />
    <line x1="128" y1="66" x2="135" y2="62" stroke={ink} stroke-width="3" stroke-linecap="round" />
    <circle class="mono-pulse" cx="137" cy="60" r="4" fill={accent} />
    <path d="M92 76 l7 7 M99 76 l-7 7" stroke={cyan} stroke-width="2.5" stroke-linecap="round" />
    <path d="M110 77 l7 7 M117 77 l-7 7" stroke={cyan} stroke-width="2.5" stroke-linecap="round" />
    <path d="M98 92 Q104 89 110 92" stroke={cyan} stroke-width="2.5" stroke-linecap="round" />
  </svg>
)}

{variant === "sleep" && (
  <svg viewBox="0 0 120 70" fill="none" class={className} aria-hidden="true">
    <text x="86" y="30" font-family="monospace" font-weight="bold" font-size="13" fill="#5f5646" class="mono-zzz">z</text>
    <text x="96" y="22" font-family="monospace" font-weight="bold" font-size="10" fill="#5f5646" class="mono-zzz" style="animation-delay: -0.9s">z</text>
    <text x="104" y="15" font-family="monospace" font-weight="bold" font-size="8" fill="#5f5646" class="mono-zzz" style="animation-delay: -1.7s">z</text>
    <line x1="14" y1="34" x2="7" y2="30" stroke={ink} stroke-width="3" stroke-linecap="round" />
    <circle cx="5.5" cy="28" r="3.5" fill={accent} />
    <rect x="14" y="30" width="46" height="34" rx="10" fill={banner} stroke={ink} stroke-width="3" />
    <path d="M27 46 q4 4 8 0" stroke={cyan} stroke-width="2.5" stroke-linecap="round" fill="none" />
    <path d="M43 46 q4 4 8 0" stroke={cyan} stroke-width="2.5" stroke-linecap="round" fill="none" />
    <rect x="60" y="38" width="38" height="26" rx="9" fill={paper2} stroke={ink} stroke-width="3" />
    <circle cx="76" cy="51" r="3.5" fill={accent} />
    <ellipse cx="104" cy="62" rx="8" ry="4" fill={paper2} stroke={ink} stroke-width="2.5" />
  </svg>
)}
