---
import SectionTitle from "./SectionTitle.astro"
import Monigote from "./Monigote.astro"

const email = "jose.inform2@gmail.com"
const social = [
  { label: "GitHub", url: "https://github.com/jsalascan" },
  { label: "LinkedIn", url: "https://www.linkedin.com/in/jsalascan/" },
]
---

<section id="contacto" class="py-24 border-t-2 border-edge">
  <div class="max-w-5xl mx-auto px-6">

    <SectionTitle number="04" label="Contacto" />

    <div class="grid md:grid-cols-2 gap-16 items-center">

      <!-- Texto izquierda -->
      <div class="reveal">
        <p class="text-3xl font-black leading-snug mb-4">
          ¿Hablamos?
        </p>
        <p class="text-ink-soft leading-relaxed mb-6">
          Si tienes un proyecto en mente, una oferta o simplemente quieres
          saludar, escríbeme un correo y te respondo lo antes posible.
        </p>
        <div class="flex flex-wrap gap-3">
          {social.map((item) => (
            <a
              href={item.url}
              target="_blank"
              class="px-5 py-2.5 border-2 border-edge text-ink text-sm font-bold rounded-full hover:border-ink transition-colors"
            >
              {item.label} ↗
            </a>
          ))}
        </div>
      </div>

      <!-- Tarjeta de correo derecha -->
      <div class="reveal reveal-delay-1">
        <div class="flex flex-col items-center gap-5 p-10 bg-paper-2 border-2 border-edge rounded-3xl text-center">
          <Monigote variant="wave" class="w-28" />
          <p class="font-mono text-xs uppercase text-ink-soft">// Sin formularios, directo a mi bandeja</p>
          <a
            href={`mailto:${email}`}
            class="px-7 py-3 bg-accent text-white text-sm font-bold rounded-full hover:bg-ink transition-colors"
          >
            Enviar correo
          </a>
          <button
            id="copy-email"
            data-email={email}
            class="font-mono text-xs uppercase text-ink-soft hover:text-accent transition-colors cursor-pointer"
          >
            {email} · copiar
          </button>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  function initCopyEmail() {
    const btn = document.getElementById("copy-email") as HTMLButtonElement | null
    if (!btn) return

    btn.onclick = async () => {
      const email = btn.dataset.email || ""
      try {
        await navigator.clipboard.writeText(email)
        btn.textContent = "¡copiado!"
      } catch {
        btn.textContent = email
      }
      setTimeout(() => {
        btn.textContent = `${email} · copiar`
      }, 2000)
    }
  }

  initCopyEmail()
  document.addEventListener("astro:page-load", initCopyEmail)
</script>
